<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="IPOS.SA.ACC.StaffAccountManagement">
  <grid id="27dc6" binding="MainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="1288" height="651"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="d02" binding="ContentPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints border-constraint="Center"/>
        <properties>
          <background color="-657416"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="44b99" binding="HeaderPanel" layout-manager="FlowLayout" hgap="10" vgap="50" flow-align="1">
            <constraints border-constraint="North"/>
            <properties>
              <background color="-983809"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="b0005" binding="CenterPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="Center"/>
            <properties>
              <background color="-657416"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="c7765" binding="FooterPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
                <margin top="0" left="0" bottom="0" right="0"/>
                <constraints border-constraint="South"/>
                <properties>
                  <background color="-983809"/>
                </properties>
                <border type="none"/>

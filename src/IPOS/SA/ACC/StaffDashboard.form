<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="IPOS.SA.ACC.StaffDashboard">
  <grid id="27dc6" binding="MainPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
    <margin top="0" left="0" bottom="0" right="0"/>
    <constraints>
      <xy x="20" y="20" width="1060" height="625"/>
    </constraints>
    <properties/>
    <border type="none"/>
    <children>
      <grid id="14a1" binding="ContentPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
        <constraints>
          <grid row="0" column="0" row-span="1" col-span="1" vsize-policy="3" hsize-policy="3" anchor="0" fill="3" indent="0" use-parent-layout="false"/>
        </constraints>
        <properties>
          <background color="-1710362"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="e5830" binding="HeaderPanel" layout-manager="FlowLayout" hgap="10" vgap="50" flow-align="1">
            <constraints border-constraint="North"/>
            <properties>
              <background color="-983809"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="df10" binding="NavPanel" layout-manager="FlowLayout" hgap="90" vgap="10" flow-align="1">
            <constraints border-constraint="West"/>
            <properties>
              <background color="-15850192"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="78945" binding="FooterPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints border-constraint="South"/>
            <properties>
              <background color="-983809"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
        </children>
      </grid>
    </children>
  </grid>
</form>

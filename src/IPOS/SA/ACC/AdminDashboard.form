<?xml version="1.0" encoding="UTF-8"?>
<form xmlns="http://www.intellij.com/uidesigner/form/" version="1" bind-to-class="IPOS.SA.ACC.AdminDashboard">
  <grid id="27dc6" binding="MainPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
    <constraints>
      <xy x="20" y="20" width="1016" height="645"/>
    </constraints>
    <properties>
      <minimumSize width="800" height="500"/>
      <opaque value="true"/>
      <preferredSize width="800" height="500"/>
    </properties>
    <border type="none"/>
    <children>
      <grid id="85862" binding="ContentPanel" layout-manager="BorderLayout" hgap="120" vgap="0">
        <constraints border-constraint="Center"/>
        <properties>
          <background color="-657414"/>
          <minimumSize width="400" height="128"/>
        </properties>
        <border type="none"/>
        <children>
          <grid id="91edf" binding="FooterPanel" layout-manager="GridLayoutManager" row-count="1" column-count="1" same-size-horizontally="false" same-size-vertically="false" hgap="-1" vgap="-1">
            <margin top="0" left="0" bottom="0" right="0"/>
            <constraints border-constraint="South"/>
            <properties>
              <background color="-983809"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
          <grid id="907ee" binding="CenterPanel" layout-manager="BorderLayout" hgap="0" vgap="0">
            <constraints border-constraint="Center"/>
            <properties>
              <background color="-657416"/>
            </properties>
            <border type="none"/>
            <children>
              <grid id="b376f" binding="CardsPanel" layout-manager="FlowLayout" hgap="5" vgap="5" flow-align="1">
                <constraints border-constraint="North"/>
                <properties>
                  <background color="-657416"/>
                </properties>
                <border type="none"/>
                <children/>
              </grid>
              <component id="f84d7" class="javax.swing.JTable" binding="OrderStatusTable">
                <constraints border-constraint="West"/>
                <properties/>
              </component>
              <component id="304d5" class="javax.swing.JTable" binding="LowStockTable">
                <constraints border-constraint="East"/>
                <properties/>
              </component>
            </children>
          </grid>
          <grid id="a14b7" binding="HeaderPanel" layout-manager="FlowLayout" hgap="10" vgap="50" flow-align="1">
            <constraints border-constraint="North"/>
            <properties>
              <background color="-983809"/>
            </properties>
            <border type="none"/>
            <children/>
          </grid>
        </children>
      </grid>
      <grid id="c98c9" binding="NavPanel" layout-manager="FlowLayout" hgap="90" vgap="10" flow-align="1">
        <constraints border-constraint="West"/>
        <properties>
          <background color="-15649206"/>
        </properties>
        <border type="none"/>
        <children/>
      </grid>
    </children>
  </grid>
</form>
